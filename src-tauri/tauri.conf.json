{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DunCrew",
  "version": "1.0.0",
  "identifier": "com.duncrew.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DunCrew - AI Operating System",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http: https: ws: wss:; img-src 'self' data: blob: https:"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/duncrew-server"
    ],
    "resources": {
      "resources/openclaw-extension/index.ts": "openclaw-extension/index.ts",
      "resources/openclaw-extension/openclaw.plugin.json": "openclaw-extension/openclaw.plugin.json",
      "resources/openclaw-extension/package.json": "openclaw-extension/package.json",
      "resources/openclaw-extension/tsconfig.json": "openclaw-extension/tsconfig.json",
      "resources/openclaw-extension/src/nexus-manager.ts": "openclaw-extension/src/nexus-manager.ts",
      "resources/openclaw-extension/src/system-brief.ts": "openclaw-extension/src/system-brief.ts",
      "resources/openclaw-extension/src/gene-pool.ts": "openclaw-extension/src/gene-pool.ts",
      "resources/openclaw-extension/src/signal-matcher.ts": "openclaw-extension/src/signal-matcher.ts"
    },
    "windows": {
      "wix": {
        "language": ["zh-CN", "en-US"]
      }
    }
  }
}