{
  "name": "@ddos/openclaw-extension",
  "version": "1.0.0",
  "description": "DunCrew Nexus integration plugin for OpenClaw — SOP-driven task execution, experience tracking, Gene Pool self-healing, and adaptive context injection.",
  "main": "index.ts",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "duncrew",
    "nexus",
    "sop",
    "agent"
  ],
  "files": [
    "index.ts",
    "src/",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": ["./index.ts"],
    "install": {
      "npmSpec": "@ddos/openclaw-extension"
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.5"
  }
}
